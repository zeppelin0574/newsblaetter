# Optional: enable AI rewriting. If unset, the MVP uses a local fallback summary.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30

# Optional Gmail/SMTP email push.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=true

# Optional Telegram push.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional Feishu group custom bot push.
# FEISHU_WEBHOOK_URL can be the full Webhook URL or only the token after /hook/.
# FEISHU_SECRET is the custom bot signing secret, not the Feishu app App Secret.
FEISHU_WEBHOOK_URL=
FEISHU_SECRET=

# Optional timezone override.
NEWS_TIMEZONE=Europe/Berlin
