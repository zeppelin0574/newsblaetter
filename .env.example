# Optional: enable AI rewriting. If unset, the MVP uses a local fallback summary.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional email push.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=true

# Optional Telegram push.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional Feishu custom bot push.
FEISHU_WEBHOOK_URL=
FEISHU_SECRET=

# Optional timezone override.
NEWS_TIMEZONE=Europe/Berlin
